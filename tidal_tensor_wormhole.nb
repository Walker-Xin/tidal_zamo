         "Lambda"}], "]"}], ",", "r"}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"solplus", "[", 
     RowBox[{"var1_", ",", "var2_", ",", "var3_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"spin", "=", "var1"}], ",", 
        RowBox[{"charge", "=", "var2"}], ",", 
