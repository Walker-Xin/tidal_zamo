          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Ralt", "[", 
              RowBox[{
              "rsol", ",", "1", ",", "lzsol", ",", "var1", ",", "var2", ",", 
               "0", ",", "1", ",", "var3"}], "]"}], "==", "0"}], "&&", 
            RowBox[{
             RowBox[{"dRaltdr", "[", 
              RowBox[{
              "rsol", ",", "1", ",", "lzsol", ",", "var1", ",", "var2", ",", 
               "0", ",", "1", ",", "var3"}], "]"}], "==", "0"}], "&&", 
            RowBox[{"rsol", ">", "0"}], "&&", 
            RowBox[{"lzsol", ">", "0"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"rsol", ",", "lzsol"}], "}"}], ",", "Reals", ",", 
