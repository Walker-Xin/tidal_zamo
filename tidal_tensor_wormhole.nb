Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ralt", "[", 
     RowBox[{
     "r_", ",", "ep_", ",", "lz_", ",", "a_", ",", "Q_", ",", "e_", ",", "m_",
       ",", "Lambda_"}], "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"ep", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"r", "^", "2"}], "+", 
           RowBox[{"a", "^", "2"}]}], ")"}]}], "-", 
        RowBox[{"a", "*", "lz"}], "-", 
        RowBox[{"e", "*", "Q", "*", "r"}]}], ")"}], "^", "2"}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"r", "^", "2"}], "-", 
        RowBox[{"2", "*", "r"}], "+", 
        RowBox[{"a", "^", "2"}], "+", 
        RowBox[{"Q", "^", "2"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"m", "^", "2"}], "*", 
         RowBox[{"r", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"a", "*", "ep"}], "-", "lz"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"lz", "^", "2"}], "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Lambda", "^", "2"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Lambda", "^", "2"}]}], ")"}]}]}]}], ")"}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dRaltdr", "[", 
     RowBox[{
     "r_", ",", "ep_", ",", "lz_", ",", "a_", ",", "Q_", ",", "e_", ",", "m_",
       ",", "Lambda_"}], "]"}], "=", 
    RowBox[{"D", "[", 
