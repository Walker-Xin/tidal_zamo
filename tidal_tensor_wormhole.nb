Cell["\<\
Use Mathematica for complete eigen computation
Mathematica is extremely slow at this (~50 mins per run)
Unless absolutely necessary, use C++ script instead (~1 second per run)\
\>", "Text",
 CellChangeTimes->{
  3.935054708309821*^9, {3.935148983662463*^9, 
   3.935149002381863*^9}},ExpressionUUID->"0cc7903d-0aa1-4b81-ad1c-\
b12cb8d93dd4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"length", "=", "5000"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "large", " ", "enough", " ", "to", " ", "cover", " ", "interesting", " ", 
    "physics"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"outputtot", "=", " ", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", " ", 
      RowBox[{"{", "length", "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"asub", "=", "0.9"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Msub", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"epsub", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qsub", "=", "1.9855427062707292"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lzsub", "=", "2.4406204372683984"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ksub", "=", 
    RowBox[{"qsub", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"lzsub", "-", 
        RowBox[{"asub", "*", "epsub"}]}], ")"}], "^", "2"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"outputtot", "[", 
      RowBox[{"[", "i", "]"}], "]"}], "=", 
     RowBox[{"Eigensystem", "[", 
      RowBox[{"ClocH", "/.", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a", "->", "asub"}], ",", 
         RowBox[{"M", "->", "Msub"}], ",", 
         RowBox[{"ep", "->", "epsub"}], ",", 
         RowBox[{"q", "->", "qsub"}], ",", 
         RowBox[{"lz", "->", "lzsub"}], ",", 
         RowBox[{"r", "->", 
          RowBox[{"rlist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"theta", "->", 
          RowBox[{"thetalist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"dt", "->", 
          RowBox[{"dtlist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"dr", "->", 
          RowBox[{"drlist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"dtheta", "->", 
          RowBox[{"dthetalist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"dphi", "->", 
          RowBox[{"dphilist", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}]}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "length"}], "}"}]}], "\[IndentingNewLine]", 
   "]"}], "//", "AbsoluteTiming"}]}], "Input",
